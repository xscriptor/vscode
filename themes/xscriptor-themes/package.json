{
  "name": "xscriptor-themes",
  "displayName": "Xscriptor Themes",
  "description": "Collection of themes for Visual Studio Code by Xscriptor.",
  "version": "1.1.4",
  "publisher": "xscriptor",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "light",
    "xscriptor",
    "colors",
    "icons",
    "icon-theme"
  ],
  "icon": "image/icon.png",
  "galleryBanner": {
    "color": "#0D1117",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xscriptor/vscode",
    "directory": "themes/xscriptor-themes"
  },
  "bugs": {
    "url": "https://github.com/xscriptor/vscode/issues"
  },
  "homepage": "https://github.com/xscriptor/vscode/tree/main/themes/xscriptor-themes",
  "scripts": {
    "build:product-icons": "node icons/scripts/build-product-icons.mjs",
    "contrast:json": "node scripts/contrast-check.mjs --format json"
  },
  "contributes": {
    "themes": [
